    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.111.0"
  },
  "allowScripts": {
    "esbuild": false,
    "fsevents": false,
