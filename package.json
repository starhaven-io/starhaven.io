{
  "name": "starhaven.io",
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "wrangler deploy --config dist/client/wrangler.json",
    "deploy:dry": "npm run deploy -- --dry-run",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^6.4.7",
    "markdown-it": "^14.2.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": true,
    "sharp": true,
    "workerd": true
  }
}
