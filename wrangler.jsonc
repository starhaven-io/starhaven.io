{
  "name": "starhaven-io",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
  },
  // Astro sessions KV: pin the id so wrangler reuses the namespace instead of re-creating it each deploy.
  "kv_namespaces": [{ "binding": "SESSION", "id": "42e050cd906e40309f43ab5a34bcbb27" }],
}
