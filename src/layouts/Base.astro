---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const defaultDescription = 'Open-source tools and notes by Patrick Linnane.';

const { title, description = defaultDescription, ogImage } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
const fullTitle = title === 'starhaven.io' ? title : `${title} — starhaven.io`;
const currentYear = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="starhaven.io" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    {ogImageURL && <meta property="og:image" content={ogImageURL} />}
    {ogImageURL && <meta property="og:image:width" content="1200" />}
    {ogImageURL && <meta property="og:image:height" content="630" />}

    <meta name="twitter:card" content={ogImageURL ? 'summary_large_image' : 'summary'} />
    {ogImageURL && <meta name="twitter:image" content={ogImageURL} />}

    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="starhaven.io" href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header class="site-header">
      <div class="container">
        <nav aria-label="Main navigation">
          <a href="/" class="site-title">starhaven.io</a>
          <div class="nav-links">
            <a href="/blog/">Blog</a>
            <a href="https://github.com/starhaven-io" rel="noopener">GitHub</a>
          </div>
        </nav>
      </div>
    </header>
    <main id="main" class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <nav aria-label="Footer navigation">
          <span>© {currentYear} Patrick Linnane</span>
          <span>
            <a href="/blog/">Blog</a>
            {' · '}
            <a href="https://github.com/starhaven-io" rel="noopener">GitHub</a>
          </span>
        </nav>
        <p class="site-license">
          Prose licensed under
          <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="license noopener">CC BY-SA 4.0</a>. Code
          licensed under
          <a href="https://www.gnu.org/licenses/agpl-3.0.html" rel="license noopener">AGPL-3.0-only</a>.
        </p>
      </div>
    </footer>
  </body>
</html>
